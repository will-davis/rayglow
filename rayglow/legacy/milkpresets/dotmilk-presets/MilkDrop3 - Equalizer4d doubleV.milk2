warp_1=`//MilkDrop3 - Equalizer
warp_2=`//Created by MilkDrop2077
warp_3=`//© 2026 milkdrop3.com
warp_4=`
warp_5=`#define bar_width 0.02
warp_6=`#define bar_spacing 0.025
warp_7=`#define bar_height_scale 1.5
warp_8=`#define num_bars 32.0
warp_9=`
warp_10=`float3 hsv2rgb(float3 c) {
warp_11=`    float4 K = float4(1.0, 2.0 / 3.0, 1.0 / 3.0, 3.0);
warp_12=`    float3 p = abs(frac(c.xxx + K.xyz) * 6.0 - K.www);
warp_13=`    return c.z * lerp(K.xxx, clamp(p - K.xxx, 0.0, 1.0), c.y);
warp_14=`}
warp_15=`
warp_16=`shader_body
warp_17=`{
warp_18=`    float t = time * 0.5;
warp_19=`    float2 fragCoord = uv_orig * texsize.xy;
warp_20=`
warp_21=`    // Use normalized 0-1 coordinates
warp_22=`    uv = fragCoord.xy / texsize.xy;
warp_23=`
warp_24=`    float3 color = float3(0.0, 0.0, 0.0);
warp_25=`
warp_26=`    // Calculate bar width including spacing to fill the screen
warp_27=`    float total_unit = 1.0 / num_bars;
warp_28=`    float actual_bar_width = total_unit - bar_spacing;
warp_29=`
warp_30=`    // FFT range: skip first 5% and last 15% to avoid extremes
warp_31=`    float fft_start = 0.05;
warp_32=`    float fft_end = 0.85;
warp_33=`    float fft_range = fft_end - fft_start;
warp_34=`
warp_35=`    // Render each bar
warp_36=`    for (float i = 0.0; i < num_bars; i += 1.0) {
warp_37=`        float bar_x_start = i * total_unit + bar_spacing * 0.5;
warp_38=`        float bar_x_end = bar_x_start + actual_bar_width;
warp_39=`
warp_40=`        // Map bar index to FFT range (avoiding extremes)
warp_41=`        float fft_pos = fft_start + (i / num_bars) * fft_range;
warp_42=`
warp_43=`        // Get FFT value and scale it
warp_44=`        float fft_val = get_fft(fft_pos);
warp_45=`        float bar_h = fft_val * bar_height_scale;
warp_46=`
warp_47=`        // Check if pixel is inside bar (centered vertically at 0.5, growing up and down)
warp_48=`        if (uv.x >= bar_x_start && uv.x < bar_x_end) {
warp_49=`            float dy = abs(uv.y - 0.5);
warp_50=`
warp_51=`            if (dy < bar_h * 0.5) {
warp_52=`                // Color based on frequency (use normalized position for hue)
warp_53=`                float hue = (i / num_bars) * 0.7 + t * 0.1;
warp_54=`                color = hsv2rgb(float3(hue, 0.8, 1.0));
warp_55=`            }
warp_56=`        }
warp_57=`    }
warp_58=`
warp_59=`    // Gamma correction
warp_60=`    float4 fragColor = float4(pow(color, float3(1.0 / 2.2, 1.0 / 2.2, 1.0 / 2.2)), 1.0);
warp_61=`    ret = fragColor;
warp_62=`}
comp_1=`shader_body
comp_2=`{
comp_3=`//MilkDrop3 Flip Mode:
comp_4=`uv = 1-uv;
comp_5=`
comp_6=`    ret = tex2D(sampler_main, uv).xyz;
comp_7=`    ret *= 1.28; //gamma
comp_8=`    ret *= hue_shader; //old hue shader effect
comp_9=`    ret *= ret; //darken
comp_10=`//MilkDrop3 Color Mode:
comp_11=`ret /= float3(0.9,-2.0,1.6);
comp_12=`}
[PRESET2_END]
