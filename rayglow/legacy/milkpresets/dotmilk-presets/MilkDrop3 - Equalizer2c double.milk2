warp_41=`
warp_42=`float glow_rect(float2 uv3, float2 pos, float2 size, float glow)
warp_43=`{
warp_44=`    float2 d = abs(uv3 - pos) - size * 0.5;
warp_45=`    float dist = length(max(d, 0.0)) + min(max(d.x, d.y), 0.0);
warp_46=`    return exp(-dist * glow);
warp_47=`}
warp_48=` shader_body
warp_49=`{
warp_50=`    uv = uv_orig;
warp_51=`
warp_52=`    float3 color = float3(0.0, 0.0, 0.0);
warp_53=`
warp_54=`    // ---- AUTO WIDTH (fills entire screen) ----
warp_55=`    float spacing = BAR_SPACING;
warp_56=`    float total_spacing = (NUM_BARS - 1) * spacing;
warp_57=`
warp_58=`    float bar_width = (1.0 - total_spacing) / NUM_BARS;
warp_59=`
warp_60=`    for(int i = 0; i < NUM_BARS; i++)
warp_61=`    {
warp_62=`        float fi = float(i);
warp_63=`
warp_64=`        // perfectly packed from x=0 to x=1
warp_65=`        float bar_x = fi * (bar_width + spacing) + bar_width * 0.5;
warp_66=`
warp_67=`        // ---- CONTROL HEIGHT HERE ----
warp_68=`        float fft_val = get_bar_height(fi);
warp_69=`
warp_70=`        // reduce vertical scale (was too tall)
warp_71=`        float bar_h = saturate(fft_val * 0.6);
warp_72=`
warp_73=`        // grow from bottom
warp_74=`        float2 bar_pos  = float2(bar_x, bar_h * 0.25);
warp_75=`        float2 bar_size = float2(bar_width, bar_h);
warp_76=`
warp_77=`        float bar  = rect(uv, bar_pos, bar_size);
warp_78=`        float glow = glow_rect(uv, bar_pos, bar_size, 10.0);
warp_79=`
warp_80=`        float3 bar_color = float3(
warp_81=`            BAR_COLOR_R + fft_val * 0.4,
warp_82=`            BAR_COLOR_G - fft_val * 0.3,
warp_83=`            BAR_COLOR_B
warp_84=`        );
warp_85=`
warp_86=`        color += bar * bar_color;
warp_87=`        color += glow * bar_color * GLOW_INTENSITY;
warp_88=`    }
warp_89=`
warp_90=`    float beat = get_fft(0.1) + get_fft(0.2);
warp_91=`    color += float3(beat * 0.08, beat * 0.08, beat * 0.08);
warp_92=`
warp_93=`    ret = float4(color, 1.0);
warp_94=`}
warp_95=`
warp_96=`
comp_1=`shader_body
comp_2=`{//MilkDrop3 Flip Mode:
comp_3=`uv = 1-uv;
comp_4=`
comp_5=`
