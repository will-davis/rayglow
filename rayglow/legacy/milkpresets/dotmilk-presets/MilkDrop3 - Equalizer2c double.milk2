warp_1=`//MilkDrop3 - Equalizer
warp_2=`//Created by MilkDrop2077
warp_3=`//© 2026 milkdrop3.com
warp_4=`
warp_5=`#define NUM_BARS 62
warp_6=`#define BAR_WIDTH 0.025
warp_7=`#define BAR_SPACING 0.005
warp_8=`#define BAR_COLOR_R 0.2
warp_9=`#define BAR_COLOR_G 0.8
warp_10=`#define BAR_COLOR_B 1.0
warp_11=`#define GLOW_INTENSITY 0.0
warp_12=`#define SMOOTHING 0.15
warp_13=`
warp_14=`float2 hash22(float2 p)
warp_15=`{
warp_16=`    float3 p3 = frac(float3(p.xyx) * float3(0.1031, 0.1030, 0.0973));
warp_17=`    p3 += dot(p3, p3.yzx + 33.33);
warp_18=`    return frac((p3.xx + p3.yz) * p3.zy);
warp_19=`}
warp_20=`
warp_21=`float smooth_fft(float pos)
warp_22=`{
warp_23=`    float base = get_fft(pos);
warp_24=`    float neighbor1 = get_fft(pos + 0.01);
