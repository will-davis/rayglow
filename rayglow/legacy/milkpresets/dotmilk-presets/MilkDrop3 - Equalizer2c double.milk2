comp_9=`    ret *= ret; //darken
comp_10=`//MilkDrop3 Color Mode:
comp_11=`ret /= float3(2.4,1.9,-0.9);
comp_12=`//MilkDrop3 Solarize Mode:
comp_13=`ret = ret*(1-ret)*4;
