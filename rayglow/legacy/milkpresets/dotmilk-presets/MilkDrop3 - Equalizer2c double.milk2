warp_26=`    return (base + neighbor1 + neighbor2) / 3.0;
warp_27=`}
warp_28=`
warp_29=`float get_bar_height(float index)
warp_30=`{
warp_31=`    float fft_pos = index / float(NUM_BARS);
warp_32=`    float raw_fft = smooth_fft(fft_pos);
warp_33=`    return pow(raw_fft, 0.7) * 2.5;
warp_34=`}
warp_35=`
warp_36=`float rect(float2 uv2, float2 pos, float2 size)
warp_37=`{
warp_38=`    float2 d = abs(uv2 - pos) - size * 0.5;
warp_39=`    return 1.0 - step(0.0, max(d.x, d.y));
