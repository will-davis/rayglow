warp_1=`//MilkDrop3 - Equalizer
warp_2=`//Created by MilkDrop2077
warp_3=`//© 2026 milkdrop3.com
warp_4=`
warp_5=`#define fVBars 100.0
warp_6=`#define fft_start 0.05
warp_7=`#define fft_end   0.85
warp_8=`
warp_9=`float3 B2_spline(float3 x)
warp_10=`{
warp_11=`    float3 t = 3.0 * x;
warp_12=`    float3 b0 = step(0.0, t)     * step(0.0, 1.0 - t);
warp_13=`    float3 b1 = step(0.0, t-1.0) * step(0.0, 2.0 - t);
warp_14=`    float3 b2 = step(0.0, t-2.0) * step(0.0, 3.0 - t);
warp_15=`    return 0.5 * (
warp_16=`        b0 * (t*t) +
warp_17=`        b1 * (-2.0*(t*t) + 6.0*t - 3.0) +
warp_18=`        b2 * ((3.0 - t)*(3.0 - t))
warp_19=`    );
warp_20=`}
warp_21=`
warp_22=`shader_body
warp_23=`{
warp_24=`    float t = time / 100.0;
warp_25=`    uv = uv_orig;
warp_26=`    float2 centered = uv - 1.0;
warp_27=`
warp_28=`    // --- BAR QUANTIZATION ---
warp_29=`    float xq = floor(uv.x * fVBars) / fVBars;
warp_30=`
warp_31=`    // --- MIRRORED + INVERTED FFT (Bass in center) ---
warp_32=`    float fft_uv = 1.0 - abs(2.0 * xq - 1.0);   // <-- FIXED INVERSION
warp_33=`    float fft_pos = lerp(fft_start, fft_end, fft_uv);
warp_34=`    float fSample = get_fft(fft_pos);
warp_35=`
warp_36=`    // --- HARD BAR SPACING ---
warp_37=`    float squarewave = sign(fmod(uv.x, 1.0/fVBars) - 0.004);
warp_38=`    float fft = squarewave * fSample * 0.5;
warp_39=`
warp_40=`    // --- VERTICAL STRIPING ---
warp_41=`    float fHBars = 100.0;
warp_42=`    float fVSpacing = 0.180;
warp_43=`    float fVFreq = uv.y * 3.14;
warp_44=`    fVFreq = sign(sin(fVFreq * fHBars) + 1.0 - fVSpacing);
warp_45=`
warp_46=`    // --- B-SPLINE COLOR ---
warp_47=`    float3 spline_args = frac(float3(
warp_48=`        uv.x - t,
warp_49=`        uv.x - t - 1.0/3.0,
warp_50=`        uv.x - t - 2.0/3.0
warp_51=`    ));
warp_52=`    float3 spline = B2_spline(spline_args);
warp_53=`
warp_54=`    float f = abs(centered.y);
warp_55=`    float3 base_color = float3(1.0,1.0,1.0) - f * spline;
warp_56=`    float3 flame_color = pow(base_color, 3.0);
warp_57=`
warp_58=`    // --- HEIGHT MASK ---
warp_59=`    float mask = 1.0 - step(fft, abs(0.3 - uv.y));
warp_60=`    float3 col = flame_color * mask * fVFreq;
warp_61=`
warp_62=`    // --- TOP DIMMING ---
warp_63=`    float tt = 0.3 - uv.y;
warp_64=`    float df = sign(tt);
warp_65=`    df = (df + 1.0) / 0.5;
warp_66=`    col -= col * df * 0.180;
warp_67=`
warp_68=`    // Gamma correction
warp_69=`    col = pow(col, 1.0/2.2);
warp_70=`
warp_71=`    ret = float4(col, 1.0);
warp_72=`}
warp_73=`
comp_1=`shader_body
comp_2=`{//MilkDrop3 Flip Mode:
comp_3=`uv = 1-uv;
comp_4=`
comp_5=`ret = tex2D(sampler_main, uv).xyz;
comp_6=`}
[PRESET2_END]
