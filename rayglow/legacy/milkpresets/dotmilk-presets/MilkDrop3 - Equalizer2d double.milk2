warp_1=`#define NUM_BARS 64
warp_2=`#define BAR_COLOR_R 0.1
warp_3=`#define BAR_COLOR_G 0.8
warp_4=`#define BAR_COLOR_B 1.0
warp_5=`#define GLOW_INTENSITY 0.13
warp_6=`#define SMOOTHING 0.15
warp_7=`
warp_8=`float smooth_fft(float pos)
warp_9=`{
warp_10=`    float base = get_fft(pos);
warp_11=`    float neighbor1 = get_fft(pos + 0.01);
warp_12=`    float neighbor2 = get_fft(pos - 0.01);
warp_13=`    return (base + neighbor1 + neighbor2) / 3.0;
warp_14=`}
warp_15=`
warp_16=`float get_bar_height(float index)
warp_17=`{
warp_18=`    float fft_pos = index / float(NUM_BARS);
warp_19=`    float raw_fft = smooth_fft(fft_pos);
warp_20=`    return pow(raw_fft, 0.7) * 2.5;
warp_21=`}
warp_22=`
warp_23=`float rect(float2 uv2, float2 pos, float2 size)
warp_24=`{
warp_25=`    float2 d = abs(uv2 - pos) - size * 0.5;
warp_26=`    return 1.0 - step(0.0, max(d.x, d.y));
warp_27=`}
warp_28=`
warp_29=`float glow_rect(float2 uv3, float2 pos, float2 size, float glow)
warp_30=`{
warp_31=`    float2 d = abs(uv3 - pos) - size * 0.5;
warp_32=`    float dist = length(max(d, 0.0)) + min(max(d.x, d.y), 0.0);
warp_33=`    return exp(-dist * glow);
warp_34=`}
warp_35=`
warp_36=`shader_body
warp_37=`{
warp_38=`    uv = uv_orig;
warp_39=`
warp_40=`    float3 color = float3(0.0, 0.0, 0.0);
warp_41=`
warp_42=`    // Automatically fit exactly 64 bars across full width
warp_43=`    float barWidth = 1.0 / float(NUM_BARS);
warp_44=`    float spacing = barWidth * 0.15;      // 15% spacing
warp_45=`    float finalWidth = barWidth - spacing;
warp_46=`
warp_47=`    for(int i = 0; i < NUM_BARS; i++)
warp_48=`    {
warp_49=`        float fi = float(i);
warp_50=`
warp_51=`        float bar_x = (fi + 0.5) / float(NUM_BARS);
warp_52=`        float bar_h = get_bar_height(fi);
warp_53=`
warp_54=`        float2 bar_pos = float2(bar_x, bar_h * 0.05);
warp_55=`        float2 bar_size = float2(finalWidth, bar_h);
warp_56=`
warp_57=`        float bar = rect(uv, bar_pos, bar_size);
warp_58=`        float glow = glow_rect(uv, bar_pos, bar_size, 10.0);
warp_59=`
warp_60=`        float fft_val = get_fft(fi / float(NUM_BARS));
warp_61=`
warp_62=`        float3 normal_color = float3(
warp_63=`            BAR_COLOR_R + fft_val * 1.0,
warp_64=`            BAR_COLOR_G - fft_val * 2.5,
warp_65=`            BAR_COLOR_B - fft_val * 2.5
warp_66=`        );
warp_67=`
warp_68=`        float whiteMask = step(0.8, fft_val);
warp_69=`        float3 bar_color = lerp(normal_color, float3(1.0,1.0,1.0), whiteMask);
warp_70=`
warp_71=`        color += bar * bar_color;
warp_72=`        color += glow * bar_color * GLOW_INTENSITY;
warp_73=`    }
warp_74=`
warp_75=`    float beat = get_fft(0.1) + get_fft(0.2);
warp_76=`    color += float3(beat * 0.1, beat * 0.05, beat * 0.2);
warp_77=`
warp_78=`    ret = float4(color, 1.0);
warp_79=`}
comp_1=`shader_body
comp_2=`{//MilkDrop3 Flip Mode:
comp_3=`uv = 1-uv;
comp_4=`
comp_5=`    ret = GetPixel(uv);
comp_6=`}
[PRESET1_END]

