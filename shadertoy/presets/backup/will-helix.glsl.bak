#define S smoothstep

// iChannel0: audio
// iChannel1: bufA

// theta replaces iTime: it comes from the Buffer A integrator, which
// accumulates theta += v * dt (forward Euler) with v steered by the bass.
// Same anatomy as before — sin(theta * speed) — but now the *rate* of the
// helix breathes with the music instead of the phase snapping around.

vec4 Line(vec2 uv, float theta, float amp, float speed, float height, vec3 col) {
    uv.y += S(1., 0., abs(uv.x)) * sin(theta * speed + uv.x * height) * amp;
    return vec4(S(.11 * S(.5, .9, abs(uv.x)), 0., abs(uv.y) - .004) * col, 1.0) * S(1., .3, abs(uv.x));
}

void mainImage(out vec4 O, in vec2 I) {
    vec2 uv = (I - 0.5 * iResolution.xy) / (iResolution.y * 5.0);
    vec4 stateA = texelFetch(iChannel1, ivec2(0), 0);
    float theta = stateA.x;   // integrated time
    float amp   = stateA.z;   // smoothed wave amplitude (was the literal .1)
    O = vec4 (0.);
    for (float i = 0.; i <= 10.; i += 1.0) {
        // float treble = texture(iChannel0, vec2(0.99, 0.25)).r;
        // float bass = texture(iChannel0, vec2(0.01, 0.25)).r;
        float t = i / 10.;
        O += Line(uv, theta, amp * 1., t, 5. + t, vec3(sin(t * 2.5), sin(t * 5.), sin(t * 10.)));
    }
}
