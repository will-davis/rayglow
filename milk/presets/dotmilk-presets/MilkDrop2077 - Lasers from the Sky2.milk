per_frame_88=n=0; loop (maxpts, gmegabuf(n+6)=0; n+=recsize);
per_frame_89=s = 0; i = 0;
per_frame_90=loop (maxstrings,
per_frame_91=ibase = s*recsize;
per_frame_92=start = megabuf (ibase+1);
