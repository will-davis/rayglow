shape_0_per_frame1=// ------------------------------------------------------------
shape_0_per_frame2=// Torus to Sphere morph by MilkDrop2077. Can't remember the 
shape_0_per_frame3=// og author of this dots shape but thanks to him!
shape_0_per_frame4=// ------------------------------------------------------------
shape_0_per_frame5=
shape_0_per_frame6=pigtemp=int(pow(5,42));
shape_0_per_frame7=num_inst=if(above(pigtemp,1024),1024,pigtemp);
shape_0_per_frame8=
shape_0_per_frame9=t1 = time/3;
shape_0_per_frame10=t2 = time/4;
shape_0_per_frame11=rad = 0.01;
shape_0_per_frame12=t3 = time/50;
shape_0_per_frame13=
shape_0_per_frame14=r = instance/num_inst;
shape_0_per_frame15=size = 0.3;
shape_0_per_frame16=nc = sqrt(num_inst);
shape_0_per_frame17=
shape_0_per_frame18=m = 0.5 + 0.5*sin(time/6);      // 0..1
shape_0_per_frame19=m = m*m*(3-2*m);                // smoothstep
shape_0_per_frame20=
shape_0_per_frame21=row = int(instance/nc);
shape_0_per_frame22=col = instance - row*nc;
shape_0_per_frame23=
shape_0_per_frame24=u = 6.28*col/nc;                // 0..2pi
shape_0_per_frame25=v = 3.1415927*row/nc;           // 0..pi
shape_0_per_frame26=
shape_0_per_frame27=// ---- Shape A: exact unit sphere parameterization
shape_0_per_frame28=sx = sin(v)*cos(u);
shape_0_per_frame29=sy = sin(v)*sin(u);
shape_0_per_frame30=sz = cos(v);
shape_0_per_frame31=
shape_0_per_frame32=// ---- Shape B: torus (major angle = u, minor angle = 2*v)
shape_0_per_frame33=// "equal" here: choose R and r0 so outer radius matches sphere radius.
shape_0_per_frame34=// Sphere radius = 1. Torus outer radius = R + r0 => set R+r0 = 1.
shape_0_per_frame35=r0 = 0.30;                      // tube thickness
shape_0_per_frame36=R  = 1 - r0;                    // ensures same overall extent as sphere
shape_0_per_frame37=
shape_0_per_frame38=vv = 2*v;                       // 0..2pi
shape_0_per_frame39=tx = (R + r0*cos(vv)) * cos(u);
shape_0_per_frame40=ty = (R + r0*cos(vv)) * sin(u);
shape_0_per_frame41=tz =  r0*sin(vv);
shape_0_per_frame42=
shape_0_per_frame43=// ---- Morph blend
shape_0_per_frame44=xs = sx*(1-m) + tx*m;
shape_0_per_frame45=ys = sy*(1-m) + ty*m;
shape_0_per_frame46=zs = sz*(1-m) + tz*m;
shape_0_per_frame47=
shape_0_per_frame48=// Rotation
shape_0_per_frame49=y1 = ys*cos(t1)-zs*sin(t1);
shape_0_per_frame50=z1 = ys*sin(t1)+zs*cos(t1);
shape_0_per_frame51=x1 = z1*sin(t2)+xs*cos(t2);
shape_0_per_frame52=z2 = z1*cos(t2)-xs*sin(t2);
shape_0_per_frame53=x2 = x1*cos(t3)-y1*sin(t3);
shape_0_per_frame54=y2 = y1*cos(t3)+x1*sin(t3);
shape_0_per_frame55=
shape_0_per_frame56=// Scaling
shape_0_per_frame57=x3 = x2;
shape_0_per_frame58=y3 = y2;
shape_0_per_frame59=z3 = z2;
shape_0_per_frame60=
shape_0_per_frame61=// Projection
shape_0_per_frame62=x = 0.5 + size*(x3/(1+z3*size*1.1));
shape_0_per_frame63=y = 0.5 + size*(y3/(1+z3*size*1.1));
shape_0_per_frame64=//a = below(z3,0);
