warp_1=`#define NUM_BARS        64.0
warp_2=`#define NUM_BLOCKS      64.0
warp_3=`#define BAR_SPACING     0.005
warp_4=`#define BLOCK_SPACING   0.003
warp_5=`#define HEIGHT_SCALE    1.5
warp_6=`
warp_7=`float3 hsv2rgb(float3 c)
warp_8=`{
warp_9=`    float4 K = float4(1.0, 2.0/3.0, 1.0/3.0, 3.0);
warp_10=`    float3 p = abs(frac(c.xxx + K.xyz) * 6.0 - K.www);
warp_11=`    return c.z * lerp(K.xxx, saturate(p - K.xxx), c.y);
warp_12=`}
warp_13=`
warp_14=`shader_body
warp_15=`{
warp_16=`    uv = uv_orig;
warp_17=`    float3 color = 0;
warp_18=`
warp_19=`    float invBars   = 1.0 / NUM_BARS;
warp_20=`    float invBlocks = 1.0 / NUM_BLOCKS;
warp_21=`
warp_22=`    // ==============================
warp_23=`    // BAR INDEX
warp_24=`    // ==============================
warp_25=`    float bar_coord = uv.x / invBars;
warp_26=`    float bar_index = floor(bar_coord);
warp_27=`    float bar_local = frac(bar_coord);
warp_28=`
warp_29=`    // Proper symmetric spacing
warp_30=`    float spacing_norm = BAR_SPACING / invBars;
warp_31=`    float bar_min = spacing_norm * 0.5;
warp_32=`    float bar_max = 1.0 - spacing_norm * 0.5;
warp_33=`
warp_34=`    float inside_bar =
warp_35=`        step(0.0, bar_index) *
warp_36=`        step(bar_index, NUM_BARS - 1.0) *
warp_37=`        step(bar_min, bar_local) *
warp_38=`        step(bar_local, bar_max);
warp_39=`
warp_40=`    // ==============================
warp_41=`    // FFT
warp_42=`    // ==============================
warp_43=`    float fft_pos = lerp(0.05, 0.85, bar_index / NUM_BARS);
warp_44=`    float fft_val = get_fft(fft_pos);
warp_45=`    float bar_height = saturate(fft_val * HEIGHT_SCALE);
warp_46=`
warp_47=`    // ==============================
warp_48=`    // BLOCK INDEX
warp_49=`    // ==============================
warp_50=`    float block_coord = uv.y / invBlocks;
warp_51=`    float block_index = floor(block_coord);
warp_52=`    float block_local = frac(block_coord);
warp_53=`
warp_54=`    float block_spacing_norm = BLOCK_SPACING / invBlocks;
warp_55=`    float block_min = block_spacing_norm * 0.5;
warp_56=`    float block_max = 1.0 - block_spacing_norm * 0.5;
warp_57=`
warp_58=`    float lit_blocks = bar_height * NUM_BLOCKS;
warp_59=`
warp_60=`    float inside_block =
warp_61=`        step(block_index, lit_blocks - 1.0) *
warp_62=`        step(block_min, block_local) *
warp_63=`        step(block_local, block_max);
warp_64=`
warp_65=`    // ==============================
warp_66=`    // COLOR (smooth HSV gradient)
warp_67=`    // ==============================
warp_68=`    float height_ratio = block_index / NUM_BLOCKS;
warp_69=`
warp_70=`    float hue = lerp(0.33, 0.0, height_ratio);
warp_71=`    float3 block_color = hsv2rgb(float3(hue, 1.0, 1.0));
warp_72=`
warp_73=`    // ==============================
warp_74=`    // FINAL
warp_75=`    // ==============================
warp_76=`    float mask = inside_bar * inside_block;
warp_77=`
warp_78=`    color = block_color * mask;
warp_79=`
warp_80=`    color = pow(color, 1.0 / 2.2);
warp_81=`
warp_82=`    ret = float4(color, 1.0);
warp_83=`}
comp_1=`shader_body
comp_2=`{
comp_3=`//MilkDrop3 Flip Mode:
comp_4=`uv = 1-uv;
comp_5=`ret = tex2D(sampler_main, uv).xyz;
comp_6=`}
[PRESET2_END]
