b3x=1.000
b1ed=0.250
per_frame_init_1=bassc=0;
per_frame_init_2=midc=0;
per_frame_init_3=mcount=0;
per_frame_init_4=bcount=0;
per_frame_1=decay = 12.9;
per_frame_2=warp = 0.1;
per_frame_3=
per_frame_4=bassc = if(above(bass,bassc),bassc + bass*.07,bassc-.03);
per_frame_5=midc = if(above(mid,midc),midc + mid*.07,midc-.03);
per_frame_6=trebc = if(above(treb,trebc),trebc + treb*.07,trebc-.03);
per_frame_7=
per_frame_8=q1 = bassc;
per_frame_9=q2 = midc;
per_frame_10=q3 = trebc;
per_pixel_1=zoom = rad+pow(rad-tan(12),3+sin(q2/17));
warp_1=`shader_body
warp_2=`{
warp_3=`// MilkDrop3: MilkDrop2077 - Ferrofluid Ball1
warp_4=`// This shader will work only with md3 :)
warp_5=`
warp_6=`// sample previous frame
warp_7=`ret = tex2D(sampler_main, uv).xyz;
warp_8=`
warp_9=`// darken (decay) over time
warp_10=`ret *= 0.94; //or try: ret -= 0.004;
warp_11=`}
comp_1=`shader_body
comp_2=`{
comp_3=`// MilkDrop3: MilkDrop2077 - Ferrofluid Ball1
comp_4=`// This shader will work only with md3 :)
comp_5=`
comp_6=`ret = tex2D(sampler_main, uv).xyz;
comp_7=`}
