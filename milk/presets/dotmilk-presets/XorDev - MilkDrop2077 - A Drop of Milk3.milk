per_frame_120=q10 = 0.5;
per_frame_121=q11 = 0.38;
per_frame_122=q32 = aspecty;
per_frame_123=
per_frame_124=q3 = gmegabuf(50000)+1;
per_frame_125=q4 = gmegabuf(50005)+1;
per_frame_126=
per_frame_127=//planet pos
per_frame_128=
per_frame_129=q15 = 0.5-0.35*sin(t1);
per_frame_130=q16 = 0.5- (0.05+0.24*cos(t1) * (0.7+0.3*sin(t1/7)));
per_frame_131=
per_frame_132=q8 = (1.7+sin(time*.02+r02))*.16;
per_frame_133=q9 = (1.7+sin(time*.0157-r02))*.16;
per_frame_134=
per_frame_135=bal = min(0.85,max(0.15,bal+ dt*0.1 * atan(treb -bass - (bal-0.5)*0.1)));
per_frame_136=q12 = bal;
per_frame_137=
per_frame_138=
per_frame_139=vol = (bass+mid+treb);
per_frame_140=
per_frame_141=timepop = if(below(timepop, 0), timepop=0, timepop = timepop-0.0166);
per_frame_142=timetrig = if(above(vol, 4.25) && below(timepop, 0), timepop=0.25, timetrig);
per_frame_143=
per_frame_144=shapepos = if(above(timepop, 0.24), 8+int(rand(6)), shapepos);
per_frame_145=shapegeomtrans = if(above(timepop, 0.24), 3+int(rand(6)), shapegeomtrans);
per_frame_146=shaperot = if(above(timepop, 0.24), rand(10), shaperot);
per_frame_147=shapecolchng1 = if(above(timepop, 0.24), rand(1), shapecolchng1);  //red
