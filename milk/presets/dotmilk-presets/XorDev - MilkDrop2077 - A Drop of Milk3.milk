warp_1=`shader_body
warp_2=`{
warp_3=`// MilkDrop3: XorDev - MilkDrop2077 - A Drop of Milk3
warp_4=`// This shader will work only with md3 :)
warp_5=`
warp_6=`// Support XorDev's amazing work:
warp_7=`// https://milkdrop3.com/xor
warp_8=`
warp_9=`// sample previous frame
warp_10=`ret = tex2D(sampler_main, uv).xyz;
warp_11=`
warp_12=`// darken (decay) over time
warp_13=`ret *= 0.94; //or try: ret -= 0.004;
warp_14=`}
comp_1=`shader_body
comp_2=`{//MilkDrop3 Flip Mode:
comp_3=`uv = 1-uv;
comp_4=`
comp_5=`    ret = tex2D(sampler_main, uv).xyz;
comp_6=`    float L = lum(ret);
comp_7=`    float bw = saturate(cos(L*27 + 3)*30 - 26);
comp_8=`    float L2 = lum(GetBlur1(uv));
comp_9=`    float bw2 = saturate(cos(L*27 + 3)*3 - 6);
comp_10=`
comp_11=`    ret = float3(.1,.6,1.1)*ret.x +
comp_12=`          float3(.1,.6,.55)*ret.y + 
comp_13=`          float3(1.5,.6,.2)*ret.z;
comp_14=`
comp_15=`    ret = ret*ret * (.5 + bw*bw2*1);
comp_16=`
comp_17=`}
